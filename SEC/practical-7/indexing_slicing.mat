% Example matrix
A = reshape(1:24, 6, 4)';   % 4-by-6 matrix for examples

% By explicit indices
sub1 = A(2:3, 4:6);        % rows 2–3, cols 4–6

% Single row or column
r3 = A(3, :);              % entire 3rd row
display(r3);
c2 = A(:, 2);              % entire 2nd column
display(c2);

% Nonconsecutive indices
sel = A([1 4], [2 5]);    % rows 1 and 4, cols 2 and 5

% Using end and colon
lastTwoCols = A(:, end-1:end);
firstThreeRows = A(1:3, :);

% Linear index into column-major storage
linIdx = [2, 7, 10];
vals = A(linIdx);

% Convert (row,col) to linear indices
r = [1 3 4]; c = [2 2 6];
lin = sub2ind(size(A), r, c);
vals2 = A(lin);

% Logical mask of elements greater than 10
mask = A > 10;
selected = A(mask);        % returns column vector of matching elements

% Modify elements satisfying condition
A(mask) = -1;              % set all >10 elements to -1

% Combine conditions
mask2 = (A >= 5) & (A <= 12);
A(mask2) = A(mask2) * 2;   % double elements in range 5..12

% Replace specific entries
A(2,3) = 99;

% Replace multiple entries with a vector (sizes must match or scalar expansion)
A(1,1:3) = [10 20 30];

% Grow array by assignment
A(6,7) = 5;                % expands A, filling new positions with 0 where needed

% Set entire 2nd row to zero
A(2,:) = 0;

% Add a vector to each column (row-wise broadcasting)
v = [1;2;3;4];             % 4x1
A = A + v;                 % adds v to each column (implicit expansion)

B = ones(size(A,1),2);     % create a compatible matrix for horizontal concat
C = zeros(2, size(A,2));   % create a compatible matrix for vertical concat

% Horizontal concatenation (same number of rows)
H = [A, B];                % size: rows(A) x (cols(A)+cols(B))

% Vertical concatenation (same number of columns)
V = [A; C];                % size: (rows(A)+rows(C)) x cols(A)

% If sizes mismatch, adjust or reshape before concatenating
% e.g., make B have same number of rows
B2 = repmat(1, size(A,1), 2);
H2 = [A, B2];
